# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel ID where emails will be forwarded
DISCORD_CHANNEL_ID=your_channel_id_here

# Gmail API Credentials
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Gmail settings
GMAIL_USER_ID=me
GMAIL_QUERY=is:unread

# Anthropic API Key (for AI task parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Progress channel (optional, falls back to DISCORD_CHANNEL_ID)
DISCORD_PROGRESS_CHANNEL_ID=your_progress_channel_id_here